{
  "name": "w192-int4-mtp",
  "description": "INT4 osoi5-v0-baked + kenyan-duma MTP K=7 + W192 sliding window + loopgraph CUDA graph + fused sparse argmax + PLE scale-fold + SMP-02 slim-greedy. Targets 500+ TPS verified class.",
  "dependencies": [
    "https://wheels.vllm.ai/3e8afdf78598afc8be999a6a049be3a5fe182e48/vllm-0.22.1rc1.dev307%2Bg3e8afdf78.cu129-cp38-abi3-manylinux_2_28_x86_64.whl",
    "transformers==5.9.0",
    "jinja2==3.1.6",
    "MarkupSafe==3.0.3",
    "orjson==3.10.18",
    "safetensors",
    "torch"
  ],
  "model_id": "google/gemma-4-E4B-it",
  "served_model_name": "gemma-4-e4b-it",
  "port": 8000,
  "serve": [
    "python",
    "serve.py"
  ],
  "env": {
    "WEIGHTS_BUCKET": "hf://buckets/gemma-challenge/gemma-chiku-inu/weights/osoi5-v0-baked",
    "LOCAL_MODEL_DIR": "/tmp/osoi5-v0-baked",
    "DRAFTER_REPO": "google/gemma-4-E4B-it-qat-q4_0-unquantized-assistant",
    "LOCAL_DRAFTER_DIR": "/tmp/qat-assistant",
    "CENTROID_TOP_K": "48",
    "HF_OVERRIDES": "{\"text_config\": {\"sliding_window\": 192}}",
    "SLIDING_WINDOW": "192",
    "SPECULATIVE_CONFIG": "{\"method\":\"mtp\",\"model\":\"/tmp/qat-assistant\",\"num_speculative_tokens\":7}",
    "GENERATION_CONFIG": "vllm",
    "OVERRIDE_GENERATION_CONFIG": "{\"temperature\":0.0,\"top_p\":1.0,\"top_k\":0}",
    "GPU_MEMORY_UTILIZATION": "0.90",
    "MAX_MODEL_LEN": "4096",
    "MAX_NUM_BATCHED_TOKENS": "512",
    "MAX_NUM_SEQS": "1",
    "PERFORMANCE_MODE": "interactivity",
    "PYTORCH_CUDA_ALLOC_CONF": "max_split_size_mb:512,expandable_segments:True",
    "TCMALLOC_HINT": "/usr/lib/x86_64-linux-gnu/libtcmalloc_minimal.so.4",
    "PLE_ASSUME_VALID_TOKEN_IDS": "1",
    "PLE_FOLD_EMBED_SCALE": "1",
    "PLE_FOLD_TARGET_MODEL": "/tmp/osoi5-v0-baked",
    "PLE_SCRATCH_REUSE": "1",
    "DIXIE_SLIM_GREEDY": "1",
    "DIXIE_FUSED_ACCEPT_PREP": "1",
    "DIXIE_PREWARM_GREEDY_KERNEL": "1",
    "FUSED_SPARSE_ARGMAX": "1",
    "FUSED_SPARSE_ARGMAX_BLOCK": "64",
    "FUSED_SPARSE_ARGMAX_REQUIRE": "1",
    "LOOPGRAPH_REQUIRE_CAPTURE": "1",
    "LOOPGRAPH_PINGPONG_SLOTS": "3",
    "LOOPGRAPH_WARMUP_CALLS": "20",
    "ONEGRAPH": "1",
    "FA_SLIDING": "1",
    "FA_SLIDING_DIAG": "0",
    "DETOK_ENDONLY": "1",
    "FASTRENDER": "1",
    "FEOPT_ORJSON": "1",
    "PRECACHE_BENCH": "0",
    "PRECACHE_REQUIRE": "0",
    "LM_HEAD_PRUNE": "0",
    "PATCH_BENCH_JINJA2": "1",
    "DISABLE_LOG_STATS": "1",
    "UVICORN_LOG_LEVEL": "warning"
  }
}
